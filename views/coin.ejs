<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>CryptoTrack — <%= coin.label %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <style>
    :root{--bg:#faf8f5;--surface:#fff;--surface2:#f5f2ee;--border:#e8e2d9;--text:#1a1510;--muted:#8a8070;--accent:#c8922a;--accent-light:#fef3e2;--green:#2d7a4f;--green-light:#e8f5ee;--red:#c0392b;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh}
    nav{position:sticky;top:0;z-index:100;background:rgba(250,248,245,0.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);height:68px;padding:0 3rem;display:flex;align-items:center;justify-content:space-between}
    .nav-logo{display:flex;align-items:center;gap:0.7rem;text-decoration:none}
    .logo-box{width:36px;height:36px;background:var(--text);border-radius:9px;display:flex;align-items:center;justify-content:center;color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:700}
    .logo-name{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:600;color:var(--text)}
    .logo-name span{color:var(--accent)}
    .nav-links{display:flex;align-items:center;gap:0.5rem}
    .nav-link{text-decoration:none;color:var(--muted);font-size:0.88rem;font-weight:500;padding:0.5rem 0.9rem;border-radius:8px;transition:all 0.2s}
    .nav-link:hover,.nav-link.active{color:var(--text);background:var(--surface2)}
    .nav-right{display:flex;align-items:center;gap:1rem}
    .live-badge{display:flex;align-items:center;gap:0.4rem;background:var(--green-light);color:var(--green);border:1px solid rgba(45,122,79,0.2);border-radius:999px;padding:0.3rem 0.85rem;font-size:0.72rem;font-weight:600}
    .live-dot{width:7px;height:7px;background:var(--green);border-radius:50%;animation:pulse 1.8s infinite}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:0.4;transform:scale(0.7)}}
    .logout-btn{text-decoration:none;color:var(--muted);font-size:0.82rem;padding:0.4rem 0.8rem;border:1px solid var(--border);border-radius:8px;transition:all 0.2s}
    .logout-btn:hover{color:var(--red);border-color:var(--red)}

    .page{max-width:1200px;margin:0 auto;padding:2.5rem 3rem}

    /* BREADCRUMB */
    .breadcrumb{display:flex;align-items:center;gap:0.5rem;font-size:0.82rem;color:var(--muted);margin-bottom:1.5rem}
    .breadcrumb a{text-decoration:none;color:var(--muted);transition:color 0.2s}
    .breadcrumb a:hover{color:var(--accent)}
    .breadcrumb-sep{color:var(--border)}

    /* COIN HEADER */
    .coin-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:2.5rem}
    .coin-header-left{display:flex;align-items:center;gap:1.2rem}
    .coin-big-icon{width:72px;height:72px;border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700}
    .coin-big-name{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:700;letter-spacing:-0.02em;margin-bottom:0.2rem}
    .coin-sym-badge{display:inline-block;background:var(--surface2);border:1px solid var(--border);border-radius:6px;padding:0.2rem 0.6rem;font-size:0.75rem;font-weight:600;color:var(--muted)}
    .trade-cta{display:flex;align-items:center;gap:0.6rem;background:var(--text);color:#fff;text-decoration:none;padding:0.7rem 1.4rem;border-radius:10px;font-weight:600;font-size:0.9rem;transition:all 0.2s}
    .trade-cta:hover{background:var(--accent);transform:translateY(-1px);box-shadow:0 6px 20px rgba(200,146,42,0.3)}

    /* PRICE HERO */
    .price-hero{background:var(--text);border-radius:20px;padding:2.5rem 3rem;margin-bottom:1.5rem;color:#fff;position:relative;overflow:hidden}
    .price-hero::before{content:'';position:absolute;top:-100px;right:-80px;width:350px;height:350px;background:radial-gradient(circle,rgba(200,146,42,0.18) 0%,transparent 60%)}
    .ph-label{font-size:0.7rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;opacity:0.45;margin-bottom:0.5rem}
    .ph-price{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,6vw,5rem);font-weight:700;letter-spacing:-0.02em;color:#d4a843;line-height:1;margin-bottom:0.4rem}
    .ph-usd{opacity:0.4;font-size:0.85rem}

    /* STATS ROW */
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:2rem}
    .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:16px;padding:1.4rem 1.5rem;transition:all 0.2s}
    .stat-card:hover{border-color:var(--accent);transform:translateY(-2px);box-shadow:0 4px 16px rgba(200,146,42,0.08)}
    .sc-label{font-size:0.68rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem}
    .sc-value{font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:700;line-height:1}
    .sc-sub{font-size:0.72rem;color:var(--muted);margin-top:0.25rem}
    .val-green{color:var(--green)}
    .val-blue{color:#2c5f8a}
    .val-gold{color:var(--accent)}

    /* CHART */
    .chart-card{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:2rem;margin-bottom:1.5rem}
    .chart-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem}
    .chart-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:700}
    .chart-note{font-size:0.75rem;color:var(--muted);background:var(--surface2);border:1px solid var(--border);padding:0.3rem 0.7rem;border-radius:6px}
    .chart-wrap{position:relative;height:280px}

    /* BACK BUTTON */
    .back-btn{display:inline-flex;align-items:center;gap:0.4rem;text-decoration:none;color:var(--muted);font-size:0.85rem;padding:0.5rem 1rem;border:1px solid var(--border);border-radius:8px;transition:all 0.2s;margin-bottom:2rem}
    .back-btn:hover{color:var(--text);border-color:var(--text)}

    footer{border-top:1px solid var(--border);padding:1.5rem 3rem;display:flex;justify-content:space-between;align-items:center;color:var(--muted);font-size:0.75rem}
  </style>
</head>
<body>
  <nav>
    <a class="nav-logo" href="/markets">
      <div class="logo-box">C</div>
      <div class="logo-name">Crypto<span>Track</span></div>
    </a>
    <div class="nav-links">
      <a class="nav-link" href="/markets">Markets</a>
      <a class="nav-link" href="/trade">Trade</a>
    </div>
    <div class="nav-right">
      <div class="live-badge"><div class="live-dot"></div>Live</div>
      <a class="logout-btn" href="/logout">Sign out</a>
    </div>
  </nav>

  <div class="page">
    <div class="breadcrumb">
      <a href="/markets">Markets</a>
      <span class="breadcrumb-sep">›</span>
      <span><%= coin.label %></span>
    </div>

    <div class="coin-header">
      <div class="coin-header-left">
        <div class="coin-big-icon" style="background:<%= coin.bg %>;color:<%= coin.color %>"><%= coin.icon %></div>
        <div>
          <div class="coin-big-name"><%= coin.label %></div>
          <span class="coin-sym-badge"><%= coin.symbol %></span>
        </div>
      </div>
      <a class="trade-cta" href="/trade">Trade <%= coin.label %> →</a>
    </div>

    <% if (data) { %>
    <div class="price-hero">
      <div class="ph-label">Last Trade Price</div>
      <div class="ph-price">$<%= parseFloat(data.last_trade_price || data.price_24h || 0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
      <div class="ph-usd">United States Dollar (USD)</div>
    </div>

    <div class="stats-row">
      <div class="stat-card">
        <div class="sc-label">24h Reference Price</div>
        <div class="sc-value val-green">$<%= parseFloat(data.price_24h||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
        <div class="sc-sub">24-hour benchmark</div>
      </div>
      <div class="stat-card">
        <div class="sc-label">Volume 24h</div>
        <div class="sc-value val-blue"><%= parseFloat(data.volume_24h||0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}) %></div>
        <div class="sc-sub">Trading volume</div>
      </div>
      <div class="stat-card">
        <div class="sc-label">Symbol</div>
        <div class="sc-value val-gold"><%= data.symbol %></div>
        <div class="sc-sub">Trading pair</div>
      </div>
    </div>

    <!-- CHART -->
    <div class="chart-card">
      <div class="chart-header">
        <div class="chart-title">Price Simulation Chart</div>
        <div class="chart-note">Simulated 7-day trend based on current price</div>
      </div>
      <div class="chart-wrap">
        <canvas id="priceChart"></canvas>
      </div>
    </div>

    <% } else { %>
    <div style="background:#fdecea;border:1px solid rgba(192,57,43,0.2);border-radius:14px;padding:1.5rem;color:var(--red);text-align:center">
      ⚠ Could not load live data for <%= coin.label %>. Please go back and try again.
    </div>
    <% } %>

    <a class="back-btn" href="/markets">← Back to Markets</a>
  </div>

  <footer>
    <span>CryptoTrack · Blockchain.com Exchange API</span>
    <span>Rose Lobo · Roll No. 10668 · CRCE · Exp 4B</span>
  </footer>

  <% if(data) { %>
  <script>
    const basePrice = parseFloat('<%= data.last_trade_price || data.price_24h || 0 %>');
    const coinColor = '<%= coin.color %>';

    // Generate simulated 7-day price data around current price
    const labels = [];
    const prices = [];
    const now = new Date();
    for (let i = 6; i >= 0; i--) {
      const d = new Date(now);
      d.setDate(d.getDate() - i);
      labels.push(d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }));
      const variation = (Math.random() - 0.48) * basePrice * 0.04;
      prices.push(+(basePrice + variation * (7 - i)).toFixed(2));
    }
    prices[prices.length - 1] = basePrice;

    const ctx = document.getElementById('priceChart').getContext('2d');
    const gradient = ctx.createLinearGradient(0, 0, 0, 280);
    gradient.addColorStop(0, coinColor + '30');
    gradient.addColorStop(1, coinColor + '00');

    new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [{
          label: 'Price (USD)',
          data: prices,
          borderColor: coinColor,
          backgroundColor: gradient,
          borderWidth: 2.5,
          tension: 0.4,
          fill: true,
          pointRadius: 4,
          pointBackgroundColor: coinColor,
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointHoverRadius: 7,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1510',
            titleColor: '#fff',
            bodyColor: '#d4a843',
            padding: 12,
            cornerRadius: 10,
            callbacks: {
              label: ctx => ' $' + ctx.parsed.y.toLocaleString('en-US', {minimumFractionDigits: 2})
            }
          }
        },
        scales: {
          x: {
            grid: { color: '#e8e2d9', lineWidth: 1 },
            ticks: { color: '#8a8070', font: { size: 11, family: 'DM Sans' } },
            border: { color: '#e8e2d9' }
          },
          y: {
            grid: { color: '#e8e2d9', lineWidth: 1 },
            ticks: {
              color: '#8a8070',
              font: { size: 11, family: 'DM Sans' },
              callback: v => '$' + v.toLocaleString('en-US', {minimumFractionDigits: 0})
            },
            border: { color: '#e8e2d9' }
          }
        }
      }
    });
  </script>
  <% } %>
</body>
</html>
